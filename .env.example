# Backend selection
AI_BACKEND=codex

# CLI overrides (optional)
# CLAUDE_CMD=claude
# CLAUDE_ARGS=-p -
# CODEX_CMD=codex
# CODEX_ARGS=exec --skip-git-repo-check -s read-only -
# CODEX_HOME_OVERRIDE=.codex-home

# Enable self-critique (disabled by default, costs credits)
# Set to 'true' to enable, 'false' or omit to disable
ENABLE_SELF_CRITIQUE=false

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Contribution targeting
# CONTRIB_AUTORUN_ARGS=--contrib --1
# CONTRIB_LANE=general
# Available presets: general, crypto, devtools, frontend, data, infra, ml, docs
# CONTRIB_TOPIC_KEYWORDS=cli,sdk,api,library
# CONTRIB_SEARCH_QUERIES=python:python cli,python:python sdk,typescript:typescript cli
# CONTRIB_FIRST_PR_MODE=false
# PR_TARGETED_MAX_TOTAL_FILES=130
# PR_TARGETED_MAX_PY_FILES=75
# PR_TARGETED_ALLOW_BROAD=false
